{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Groundhog",
  "version": "0.1.0",
  "identifier": "dev.groundhog.desktop",
  "build": {
    "beforeDevCommand": "npm run vite-dev",
    "beforeBuildCommand": "npm run vite-build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "panel",
        "title": "Groundhog",
        "width": 320,
        "height": 160,
        "resizable": true,
        "decorations": true,
        "alwaysOnTop": false,
        "visible": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
