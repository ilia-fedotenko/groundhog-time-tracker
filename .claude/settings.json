{
  "permissions": {
    "allow": [
      "Bash(npx:*)",
      "Skill(update-config)"
    ]
  },
  "enabledMcpjsonServers": [
    "context7"
  ],
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/enforce-feature-branch.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/nvm-use-24.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/generate-mcp.sh"
          }
        ]
      }
    ]
  }
}
